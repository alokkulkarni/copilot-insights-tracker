# GitHub API Configuration
# Generate a Personal Access Token at https://github.com/settings/tokens
# Required scopes: read:org, read:user, manage_billing:copilot
VITE_GITHUB_TOKEN=your_github_personal_access_token_here

# GitHub Organisation name (e.g. "my-org")
VITE_GITHUB_ORG=your_github_org_name

# Optional: GitHub Enterprise Server base URL (leave blank for github.com)
VITE_GITHUB_API_BASE=https://api.github.com

# Optional: Refresh interval in milliseconds (default: 300000 = 5 minutes)
VITE_REFRESH_INTERVAL=300000
